{
  "name": "zipform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "pnpm --filter @zipform/dashboard dev",
    "build": "pnpm --filter @zipform/dashboard build",
    "lint": "pnpm --filter @zipform/dashboard lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test && node --test scripts/deployment-config.test.mjs",
    "check": "pnpm db:generate && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @zipform/data db:generate",
    "db:migrate": "pnpm --filter @zipform/data db:migrate",
    "db:migrate:deploy": "pnpm --filter @zipform/data db:migrate:deploy",
    "db:deploy": "pnpm db:generate && pnpm db:migrate:deploy",
    "db:seed": "pnpm --filter @zipform/data db:seed",
    "db:studio": "pnpm --filter @zipform/data db:studio"
  },
  "devDependencies": {
    "supabase": "^2.109.0",
    "typescript": "^5.8.3"
  }
}
