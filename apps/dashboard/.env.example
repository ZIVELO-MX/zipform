AUTH_SECRET="replace-with-a-random-secret"
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""

# PostgreSQL — Supabase (set actual values in .env.local, not .env.example)
# Pooled connection (used at runtime by the app)
# DATABASE_URL="postgresql://[user]:[password]@[host]:[port]/[db]?pgbouncer=true"
# Direct connection (used for migrations, bypasses PgBouncer)
# DIRECT_URL="postgresql://[user]:[password]@[host]:[port]/[db]"
