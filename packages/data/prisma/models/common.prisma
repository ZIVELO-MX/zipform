model Avatar {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  imageUrl String @default("")
  @@map("avatars")
}

model User {
  id                String                 @id @default(uuid()) @db.Uuid
  name              String
  username          String                 @unique
  email             String                 @unique
  role              String
  type              String                 @default("human")
  avatarUrl         String
  theme             String                 @default("system")
  passwordHash      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  sessions          Session[]
  apiKeys           ApiKey[]      @relation("apiKeyOwner")
  createdApiKeys    ApiKey[]      @relation("apiKeyCreator")
  missions          TlozMission[]
  projects          TlozProject[]
  questItems        TlozQuestItem[]
  userMissionStates TlozUserMissionState[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model PlatformMetric {
  id        String   @id
  label     String
  value     String
  tone      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_metrics")
}

model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation("apiKeyOwner", fields: [userId], references: [id], onDelete: Cascade)
  createdByUserId String    @db.Uuid
  createdBy       User      @relation("apiKeyCreator", fields: [createdByUserId], references: [id])
  name            String
  keyPrefix       String
  keyHash         String
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([createdByUserId])
  @@map("api_keys")
}
